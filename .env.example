# slowgoes — 환경변수 템플릿
#
# 사용법: 이 파일을 `.env.local` 로 복사 후 실제 값으로 채워주세요.
#   cp .env.example .env.local
#
# 모든 값은 Supabase 프로젝트 대시보드 + Google AI Studio에서 발급/조회.
# `.env.local` 은 git에 커밋되지 않습니다 (.gitignore).

# === Supabase (필수) ===
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...your-anon-key

# 서버 액션/관리자 전용 (절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...your-service-role-key

# === Google Gemini AI (필수) ===
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIzaSy...your-google-ai-key
# 사용 모델 — 기본 권장값
GEMINI_MODEL=gemini-2.0-flash

# === Supabase CLI / MCP 인증 (선택, 로컬 마이그레이션용) ===
# https://supabase.com/dashboard/account/tokens
# Claude Code Dispatch 환경에서는 Dispatch 프로젝트 시크릿에 등록하세요.
SUPABASE_ACCESS_TOKEN=sbp_...your-personal-access-token
SUPABASE_DB_PASSWORD=your-database-password
